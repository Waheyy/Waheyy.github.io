ay:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#66d9ef&#34;&gt;void&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;init_setup&lt;/span&gt;() {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#a6e22e&#34;&gt;setbuf&lt;/span&gt;(stdout,NULL);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#a6e22e&#34;&gt;setbuf&lt;/span&gt;(stderr,NULL);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;}&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#66d9ef&#34;&gt;int&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;get_num&lt;/span&gt;(&lt;span style=&#34;color:#66d9ef&#34;&gt;const&lt;/span&gt; &lt;span style=&#34;color:#66d9ef&#34;&gt;char&lt;/span&gt;&lt;span style=&#34;color:#f92672&#34;&gt;*&lt;/span&gt; prompt, &lt;span style=&#34;color:#66d9ef&#34;&gt;size_t&lt;/span&gt;&lt;span style=&#34;color:#f92672&#34;&gt;*&lt;/span&gt; num, &lt;span style=&#34;color:#66d9ef&#34;&gt;size_t&lt;/span&gt; bound) {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#a6e22e&#34;&gt;printf&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;%s&amp;gt; &amp;#34;&lt;/span&gt;, prompt);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#66d9ef&#34;&gt;int&lt;/span&gt; scanned &lt;span style=&#34;color:#f92672&#34;&gt;=&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;scanf&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;%zu&amp;#34;&lt;/span&gt;,num);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#a6e22e&#34;&gt;getchar&lt;/span&gt;();&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#66d9ef&#34;&gt;if&lt;/span&gt;((scanned &lt;span style=&#34;color:#f92672&#34;&gt;!=&lt;/span&gt; &lt;span style=&#34;color:#ae81ff&#34;&gt;1&lt;/span&gt;) &lt;span style=&#34;color:#f92672&#34;&gt;||&lt;/span&gt; (bound &lt;span style=&#34;color:#f92672&#34;&gt;&amp;amp;&amp;amp;&lt;/span&gt; &lt;span style=&#34;color:#f92672&#34;&gt;*&lt;/span&gt;num &lt;span style=&#34;color:#f92672&#34;&gt;&amp;gt;=&lt;/span&gt; bound)) {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    &lt;span style=&#34;color:#a6e22e&#34;&gt;puts&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;[-] getnum&amp;#34;&lt;/span&gt;);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    &lt;span style=&#34;color:#66d9ef&#34;&gt;return&lt;/span&gt; &lt;span style=&#34;color:#f92672&#34;&gt;-&lt;/span&gt;&lt;span style=&#34;color:#ae81ff&#34;&gt;1&lt;/span&gt;;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  }&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#66d9ef&#34;&gt;return&lt;/span&gt; &lt;span style=&#34;color:#ae81ff&#34;&gt;0&lt;/span&gt;;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;}&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;&lt;span style=&#34;color:#66d9ef&#34;&gt;void&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;get_str&lt;/span&gt;(&lt;span style=&#34;color:#66d9ef&#34;&gt;char&lt;/span&gt;&lt;span style=&#34;color:#f92672&#34;&gt;*&lt;/span&gt; buf, &lt;span style=&#34;color:#66d9ef&#34;&gt;size_t&lt;/span&gt; cap) {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#66d9ef&#34;&gt;char&lt;/span&gt; c;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#a6e22e&#34;&gt;printf&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;content&amp;gt; &amp;#34;&lt;/span&gt;);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#75715e&#34;&gt;// I&amp;#39;m so nice that you won&amp;#39;t have to deal with null bytes&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  &lt;span style=&#34;color:#66d9ef&#34;&gt;for&lt;/span&gt; (&lt;span style=&#34;color:#66d9ef&#34;&gt;int&lt;/span&gt; i &lt;span style=&#34;color:#f92672&#34;&gt;=&lt;/span&gt; &lt;span style=&#34;color:#ae81ff&#34;&gt;0&lt;/span&gt; ; i &lt;span style=&#34;color:#f92672&#34;&gt;&amp;lt;&lt;/span&gt; cap ; &lt;span style=&#34;color:#f92672&#34;&gt;++&lt;/span&gt;i) {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    &lt;span style=&#34;color:#66d9ef&#34;&gt;int&lt;/span&gt; scanned &lt;span style=&#34;color:#f92672&#34;&gt;=&lt;/span&gt; &lt;span style=&#34;color:#a6e22e&#34;&gt;scanf&lt;/span&gt;(&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#34;%c&amp;#34;&lt;/span&gt;,&lt;span style=&#34;color:#f92672&#34;&gt;&amp;amp;&lt;/span&gt;c);&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    &lt;span style=&#34;color:#66d9ef&#34;&gt;if&lt;/span&gt; (scanned &lt;span style=&#34;color:#f92672&#34;&gt;!=&lt;/span&gt;&lt;span style=&#34;color:#ae81ff&#34;&gt;1&lt;/span&gt; &lt;span style=&#34;color:#f92672&#34;&gt;||&lt;/span&gt; c&lt;span style=&#34;color:#f92672&#34;&gt;==&lt;/span&gt;&lt;span style=&#34;color:#e6db74&#34;&gt;&amp;#39;\n&amp;#39;&lt;/span&gt;) {&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;      &lt;span style=&#34;color:#66d9ef&#34;&gt;return&lt;/span&gt;;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    }&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;    buf[i] &lt;span style=&#34;color:#f92672&#34;&gt;=&lt;/span&gt; c;&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;  }&#xA;&lt;/span&gt;&lt;/span&gt;&lt;span style=&#34;display:flex;&#34;&gt;&lt;span&gt;}&#xA;&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;pre tabindex=&#34;0&#34;&gt;&lt;code&gt;&lt;/code&gt;&lt;/pre&gt;&lt;p&gt;These are the set up and general use functions. You may notice that &lt;code&gt;stdin&lt;/code&gt; is buffered and that &lt;code&gt;get_str()&lt;/code&gt; makes it so that I do not have to deal with null bytes (Thank god).&lt;/p&gt;</description>
    </item>
    <item>
      <title>NYP Dec CTF 2025 Labubu 3 different ways</title>
      <link>https://waheyy.github.io/post/labubu/labubu/</link>
      <pubDate>Wed, 31 Dec 2025 17:36:25 +0800</pubDate>
      <guid>https://waheyy.github.io/post/labubu/labubu/</guid>
      <description>&lt;h4 id=&#34;introduction&#34;&gt;Introduction:&lt;/h4&gt;&#xA;&lt;p&gt;labubu labubu labubububububu labubu labewbew labbubu labubu labu labubu labububub&lt;/p&gt;&#xA;&lt;p&gt;Labubu translation: I wrote a beginner challenge for NYP Dec CTF 2025. It is meant to be a simple introduction to &lt;strong&gt;tcache poisoning&lt;/strong&gt; with a small twist to force solvers to be more creative.&lt;/p&gt;&#xA;&lt;h4 id=&#34;table-of-contents&#34;&gt;Table of Contents:&lt;/h4&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;Prerequisites.&lt;/li&gt;&#xA;&lt;li&gt;Binary and source code review.&lt;/li&gt;&#xA;&lt;li&gt;Exploit(s)&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;h4 id=&#34;prerequisites&#34;&gt;Prerequisites:&lt;/h4&gt;&#xA;&lt;p&gt;Go read this post on the basics of &lt;a href=&#34;https://waheyy.github.io/post/liardancer/liardancerwriteup/&#34;&gt;tcache poisoning.&lt;/a&gt;&#xA;The only difference here is since the binary has the &lt;strong&gt;FULL RELRO&lt;/strong&gt; protection enabled, the binary&amp;rsquo;s &lt;strong&gt;Global Offset Table&lt;/strong&gt; (GOT) cannot be written to so we have to get creative with our write-what-where.&lt;/p&gt;</description>
    </item>
    <item>
      <title>AYCEP2025 verysecretstorage Modprobe Path overwrite</title>
      <link>https://waheyy.github.io/post/secretstorage/secretstoragewriteup/</link>
      <pubDate>Sun, 26 Oct 2025 21:39:54 +0800</pubDate>
      <guid>https://waheyy.github.io/post/secretstorage/secretstoragewriteup/</guid>
      <description>&lt;h4 id=&#34;introduction&#34;&gt;Introduction:&lt;/h4&gt;&#xA;&lt;p&gt;WHATS&amp;rsquo;S UP GUYS! Welcome back to another text based youtube video. Today we will be reading a writeup about &lt;a href=&#34;https://github.com/KaligulaArmblessed/CTF-Challenges/tree/main/AYCEP_2024/verysecretstorage&#34;&gt;verysecretstorage&lt;/a&gt;, a challenge made by &lt;a href=&#34;https://kaligulaarmblessed.github.io/&#34;&gt;Kaligula&lt;/a&gt; for AYCEP2024 (yes I am a year late and missed out greatly). This was my first kernel heap challenge as well as my first real kernel challenge and it was pretty fun.&lt;/p&gt;&#xA;&lt;h4 id=&#34;table-of-contents&#34;&gt;Table of Contents:&lt;/h4&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;Protections&lt;/li&gt;&#xA;&lt;li&gt;Binary analysis&lt;/li&gt;&#xA;&lt;li&gt;Exploit&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;h4 id=&#34;protections&#34;&gt;Protections:&lt;/h4&gt;&#xA;&lt;p&gt;Since this is my first kpwn challenge I will be going through the common protections as well as the ones that people do not talk about often in beginner writeups (in my exp pls no sue me).&lt;/p&gt;</description>
    </item>
    <item>
      <title>NYP Infosec June CTF 2025 Liardancer Writeup</title>
      <link>https://waheyy.github.io/post/liardancer/liardancerwriteup/</link>
      <pubDate>Thu, 17 Jul 2025 22:36:21 +0800</pubDate>
      <guid>https://waheyy.github.io/post/liardancer/liardancerwriteup/</guid>
      <description>&lt;h4 id=&#34;tldr&#34;&gt;TLDR;&lt;/h4&gt;&#xA;&lt;p&gt;Liardancer is a heap pwn challenge from the June NYP Infosec 2025 CTF written by &lt;a href=&#34;https://wrenches.online/nyp.html&#34;&gt;cf&lt;/a&gt; (check her writeup out).&#xA;It is a simple &lt;strong&gt;tcache poisoning&lt;/strong&gt; into a &lt;strong&gt;Global Offset Table(GOT)&lt;/strong&gt; overwrite, however with the security features of pointer mangling and the enforcement of 16 byte alignment for pointers returned by &lt;code&gt;malloc()&lt;/code&gt;.&lt;/p&gt;&#xA;&lt;h4 id=&#34;table-of-contents&#34;&gt;Table of contents:&lt;/h4&gt;&#xA;&lt;ol&gt;&#xA;&lt;li&gt;Prerequisites.&lt;/li&gt;&#xA;&lt;li&gt;Binary and Source code Review.&lt;/li&gt;&#xA;&lt;li&gt;Exploit.&lt;/li&gt;&#xA;&lt;/ol&gt;&#xA;&lt;h4 id=&#34;prerequisites&#34;&gt;Prerequisites&lt;/h4&gt;&#xA;&lt;p&gt;To do this exploit, we need to have a basic understanding of &lt;code&gt;malloc()&lt;/code&gt;, &lt;code&gt;free()&lt;/code&gt;, tcache , the GOT and the heap.&lt;/p&gt;</description>
    </item>
